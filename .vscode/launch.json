        "--flavor",
        "staging",
        "--dart-define-from-file=env/staging.json"
      ]
    },
    {
      "name": "Windows (production)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "windows",
        "--dart-define-from-file=env/production.json"
      ]
    },
    {
      "name": "Windows (staging)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "windows",
        "--dart-define-from-file=env/staging.json"
      ]
