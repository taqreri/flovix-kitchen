      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "production",
        "--dart-define-from-file=env/production.json"
      ]
    },
    {
      "name": "Android (staging)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
